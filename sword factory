local function parsePrice(t)
    if not t then return 0 end
    t=t:gsub(",",""):gsub("%$","")
    local c=t:match("([%d%.]+%a*)")
    if not c then return 0 end
    local n=tonumber(c:match("[%d%.]+"))
    if not n then return 0 end
    local s=c:match("%a+")
    if s then
        s=s:upper()
        if s=="K" then n=n*1e3 elseif s=="M" then n=n*1e6 elseif s=="B" then n=n*1e9
        elseif s=="T" then n=n*1e12 elseif s=="QD" or s=="Q" then n=n*1e15
        elseif s=="QN" then n=n*1e18 elseif s=="S" then n=n*1e21
        elseif s=="OC" then n=n*1e27 elseif s=="N" then n=n*1e30 end
    end
    return n
end

