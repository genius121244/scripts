    lbl.TextColor3=Color3.fromRGB(205,205,225)
    lbl.TextSize=11
    lbl.Font=Enum.Font.Gotham
    lbl.TextXAlignment=Enum.TextXAlignment.Left
    local dbtn=Instance.new("TextButton",f)
    dbtn.Size=UDim2.new(0.55,-8,0,24)
    dbtn.Position=UDim2.new(0.43,0,0.5,-12)
    dbtn.BackgroundColor3=Color3.fromRGB(32,32,52)
    dbtn.BorderSizePixel=0
    dbtn.Text=selected.." ▾"
    dbtn.TextColor3=Color3.fromRGB(255,255,255)
    dbtn.TextSize=11
    dbtn.Font=Enum.Font.Gotham
    Instance.new("UICorner",dbtn).CornerRadius=UDim.new(0,6)
    local isOpen=false
    local activeList=nil
    local function closeDD()
        if activeList then activeList:Destroy() activeList=nil end
        isOpen=false
    end
    local function openDD()
        closeDD() isOpen=true
        local listH=math.min(#opts*26+4,200)
        local screenW=workspace.CurrentCamera.ViewportSize.X
        local screenH=workspace.CurrentCamera.ViewportSize.Y
        local absPos=dbtn.AbsolutePosition
        local absSize=dbtn.AbsoluteSize
        local yPos=absPos.Y+absSize.Y+2
        if yPos+listH>screenH-10 then yPos=absPos.Y-listH-2 end
        yPos=math.max(yPos,5)
        local xPos=absPos.X
        if xPos+absSize.X>screenW-5 then xPos=screenW-absSize.X-5 end
        xPos=math.max(xPos,5)
        local dlist=Instance.new("Frame",screenGui)
        dlist.Size=UDim2.new(0,absSize.X,0,listH)
        dlist.Position=UDim2.new(0,xPos,0,yPos)
        dlist.BackgroundColor3=Color3.fromRGB(22,22,38)
        dlist.BorderSizePixel=0 dlist.ZIndex=200
        Instance.new("UICorner",dlist).CornerRadius=UDim.new(0,6)
        local dscroll=Instance.new("ScrollingFrame",dlist)
        dscroll.Size=UDim2.new(1,0,1,0)
        dscroll.BackgroundTransparency=1 dscroll.BorderSizePixel=0
        dscroll.ScrollBarThickness=3
        dscroll.CanvasSize=UDim2.new(0,0,0,#opts*28) dscroll.ZIndex=200
        local dl=Instance.new("UIListLayout",dscroll) dl.Padding=UDim.new(0,2)
        local dp=Instance.new("UIPadding",dscroll)
        dp.PaddingTop=UDim.new(0,2) dp.PaddingLeft=UDim.new(0,2) dp.PaddingRight=UDim.new(0,2)
        for _,opt in ipairs(opts) do
            local ob=Instance.new("TextButton",dscroll)
            ob.Size=UDim2.new(1,-4,0,24)
            ob.BackgroundColor3=opt==selected and Color3.fromRGB(55,55,115) or Color3.fromRGB(32,32,52)
            ob.BorderSizePixel=0 ob.Text=opt
            ob.TextColor3=Color3.fromRGB(215,215,235)
            ob.TextSize=11 ob.Font=Enum.Font.Gotham ob.ZIndex=201
            Instance.new("UICorner",ob).CornerRadius=UDim.new(0,4)
            ob.MouseButton1Click:Connect(function()
                selected=opt dbtn.Text=opt.." ▾"
                closeDD()
                if onChange then onChange(opt) end
                for _,b in ipairs(dscroll:GetChildren()) do
                    if b:IsA("TextButton") then
                        b.BackgroundColor3=b.Text==opt and Color3.fromRGB(55,55,115) or Color3.fromRGB(32,32,52)
                    end
                end
            end)
        end
        activeList=dlist
    end
    dbtn.MouseButton1Click:Connect(function()
        if isOpen then closeDD() else openDD() end
    end)
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 and isOpen then
            local mp=UserInputService:GetMouseLocation()
            if activeList then
                local ap=activeList.AbsolutePosition
                local as=activeList.AbsoluteSize
                if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then closeDD() end
            end
        end
    end)
    return f,function() return selected end,function(v) selected=v dbtn.Text=v.." ▾" end
end

