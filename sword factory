local function buildAnchorCFrame(tp)
    local pitchRad=math.rad(S.anchorPitch)
    local yawRad=math.rad(S.anchorYaw)
    local offset=Vector3.new(S.anchorX,S.anchorY,S.anchorZ)
    local rotatedOffset=Vector3.new(
        offset.X*math.cos(yawRad)-offset.Z*math.sin(yawRad),
        offset.Y,
        offset.X*math.sin(yawRad)+offset.Z*math.cos(yawRad)
    )
    local pos=tp+rotatedOffset
    local look=CFrame.new(pos,tp)
    return look*CFrame.Angles(pitchRad,0,0)
end

local function pickupSword(sword)
    pcall(function()
        local timeout=0
        while timeout<10 do
            if not sword.Parent then return end
            local main=sword:FindFirstChild("Main")
            if not main then return end
            local gui=main:FindFirstChildOfClass("SurfaceGui")
            if not gui then return end
            local selling=gui:FindFirstChild("Selling",true)
            if selling and selling.Text:find("Unlock in") then
                task.wait(0.5) timeout=timeout+0.5
            else break end
        end
        if not sword.Parent then return end
        local char=localplr.Character
        if not char then return end
        local rp=char:FindFirstChild("HumanoidRootPart")
        if not rp then return end
        local wasAttacking=isAttacking
        isAttacking=false
        local savedCF=rp.CFrame
        rp.Anchored=false
        local swordPos=sword:GetPivot().Position
        rp.CFrame=CFrame.new(swordPos+Vector3.new(0,2,0))
        task.wait(0.3)
        local picked=not sword.Parent
        if not picked then
            rp.CFrame=CFrame.new(swordPos+Vector3.new(0,1,0))
            task.wait(0.3)
            picked=not sword.Parent
        end
        if picked then stats.swordsCollected=stats.swordsCollected+1 end
        rp.CFrame=savedCF
        isAttacking=wasAttacking
    end)
end

local function passesFilter(data,mode,minRarity,minWorth)
    if mode=="Rarity" then
        return (RARITY_RANK[data.rarity] or 0)>=(RARITY_RANK[minRarity] or 0)
    else
        return data.worth>=minWorth
    end
end

local function presetMatches(data,preset)
    local activeSlots={}
    for _,slot in ipairs(preset.slots) do
        if slot.enabled and slot.enchant~="None" then
            table.insert(activeSlots,slot)
        end
    end
    if #activeSlots==0 then return false end
    local available={}
    for i,e in ipairs(data.enchants) do
        available[i]={name=e.name,level=e.level,used=false}
    end
    for _,slot in ipairs(activeSlots) do
        local found=false
        for _,avail in ipairs(available) do
            if not avail.used and avail.name==slot.enchant and avail.level>=slot.minLevel then
                avail.used=true
                found=true
                break
            end
        end
        if not found then return false end
    end
    return true
end

