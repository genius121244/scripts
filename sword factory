-- FARMING LOOP
local function findTarget(rp)
    local nearest=nil local nearestDist=math.huge
    local myPos=rp.Position
    local npcs=workspace:FindFirstChild("NPCs")
    if not npcs then return nil end
    for _,obj in ipairs(npcs:GetChildren()) do
        local isTarget=false
        for _,name in ipairs(TARGET_NAMES) do
            if obj.Name==name then isTarget=true break end
        end
        if isTarget then
            local h=obj:FindFirstChildWhichIsA("Humanoid")
            if h and h.Health>0 then
                local d=(myPos-obj:GetPivot().Position).Magnitude
                if d<nearestDist and d<MAX_TARGET_DISTANCE then nearestDist=d nearest=obj end
            end
        end
    end
    return nearest
end

local function getChar()
    local c=localplr.Character
    if not c then localplr.CharacterAdded:Wait() c=localplr.Character end
    return c
end

local function computePath(rp,tp)
    local path=PathfindingService:CreatePath({AgentRadius=2,AgentHeight=5,AgentCanJump=true,AgentCanClimb=false})
    local ok=pcall(function() path:ComputeAsync(rp.Position,tp) end)
    if ok and path.Status==Enum.PathStatus.Success then return path:GetWaypoints() end
    return nil
end

local lastTarget=nil local waypoints={} local waypointIdx=1 local lastWpIdx=0
local stuckTimer=0 local lastPos=nil local lastMoveTgt=nil
local isUnstucking=false local stuckResetTimer=0

task.spawn(function()
    while true do
        task.wait(0.1)
        if not farmEnabled then isAttacking=false continue end
        if isUnstucking or taskRunning or safeModeActive then isAttacking=false continue end
        local char=getChar()
        local hum=char:FindFirstChildOfClass("Humanoid")
        local rp=char:FindFirstChild("HumanoidRootPart")
        if not hum or not rp then continue end
        local target=findTarget(rp)
        if not target then isAttacking=false setStatus("Finding target...") continue end
        local tp=nil
        pcall(function() tp=target:GetPivot().Position end)
        if not tp then continue end
        local dist=(rp.Position-tp).Magnitude
        if target~=lastTarget then
            lastTarget=target waypointIdx=1 lastWpIdx=0 lastMoveTgt=nil
            isAttacking=false stuckResetTimer=0 anchorCFrame=nil
            if S.selectedMovement=="Pathfind" then waypoints=computePath(rp,tp) or {} end
        end
        if dist<S.attackRange then
            if not anchorCFrame then
                anchorCFrame=buildAnchorCFrame(tp)
                rp.CFrame=anchorCFrame
            end
            isAttacking=true stuckResetTimer=0
            setStatus("Attacking "..(target.Name or "target"))
            lastMoveTgt=nil
        else
            isAttacking=false anchorCFrame=nil
            if S.selectedMovement=="Teleport" then
                setStatus("Teleporting to target")
                tpToTarget(target) task.wait(0.1)
            else
                setStatus("Walking to target")
                if lastPos then
                    stuckTimer=stuckTimer+0.1 stuckResetTimer=stuckResetTimer+0.1
                    if stuckTimer>=0.8 then
                        if (rp.Position-lastPos).Magnitude<0.5 then
                            isUnstucking=true
                            hum:MoveTo(rp.Position) task.wait(0.1)
                            hum.Jump=true task.wait(0.3)
                            hum.Jump=true task.wait(0.3)
                            waypoints=computePath(rp,tp) or {}
                            waypointIdx=1 lastWpIdx=0 lastMoveTgt=nil
                            isUnstucking=false
                        end
                        stuckTimer=0
                    end
                    if stuckResetTimer>=10 then
                        if (rp.Position-lastPos).Magnitude<2 then
                            isAttacking=false isUnstucking=false stuckResetTimer=0
                            lastTarget=nil waypoints={}
                            resetCharacter()
                            repeat task.wait(0.1) until
                                localplr.Character and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid") and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid").Health>0
                            task.wait(3) equipSword()
                            task.wait(1) travelToArea(S.selectedArea)
                            task.wait(8) equipSword()
                        else stuckResetTimer=0 end
                    end
                end
                lastPos=rp.Position
                if #waypoints>0 and waypointIdx<=#waypoints then
                    local wp=waypoints[waypointIdx]
                    if (rp.Position-wp.Position).Magnitude<4 then waypointIdx=waypointIdx+1 lastMoveTgt=nil end
                    if waypointIdx~=lastWpIdx and waypointIdx<=#waypoints then
                        local nwp=waypoints[waypointIdx]
                        if nwp.Action==Enum.PathWaypointAction.Jump then hum.Jump=true end
                        hum:MoveTo(nwp.Position) lastWpIdx=waypointIdx
                    end
                else
                    if lastMoveTgt~=tp then hum:MoveTo(tp) lastMoveTgt=tp end
                end
            end
        end
    end
end)
