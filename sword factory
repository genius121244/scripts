local function romanToNum(r)
    local v={I=1,V=5,X=10,L=50,C=100,D=500,M=1000}
    local res,prev=0,0
    for i=#r,1,-1 do
        local cur=v[r:sub(i,i)] or 0
        if cur<prev then res=res-cur else res=res+cur end
        prev=cur
    end
    return res
end

local function getSwordInfo(sword)
    local main=sword:FindFirstChild("Main")
    if not main then return nil end
    local gui=main:FindFirstChildOfClass("SurfaceGui")
    if not gui then return nil end
    local d={}
    local rarity=gui:FindFirstChild("RarityQuality",true)
    local worth=gui:FindFirstChild("Worth",true)
    local username=gui:FindFirstChild("Username",true)
    local selling=gui:FindFirstChild("Selling",true)
    local enchFrame=gui:FindFirstChild("Enchants",true)
    d.rarity=nil
    if rarity then
        local clean=rarity.Text:gsub("<[^>]+>","")
        for _,r in ipairs(RARITIES) do
            if clean:find(r,1,true) then d.rarity=r break end
        end
    end
    d.worth=worth and parsePrice(worth.Text) or 0
    d.owner=username and username.Text or ""
    d.selling=selling and selling.Text or ""
    d.enchants={}
    if enchFrame then
        for _,lbl in ipairs(enchFrame:GetChildren()) do
            if lbl:IsA("TextLabel") and lbl.Text~="" then
                local name,level=lbl.Text:match("^(.-)%s+([IVXLCDM]+)$")
                if name and level then
                    table.insert(d.enchants,{name=name,level=romanToNum(level),levelRoman=level})
                end
            end
        end
    end
    return d
end

