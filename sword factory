-- KEY SYSTEM CONFIG
local SERVER_URL = "https://sfsbot-8y7x.onrender.com/validate"
local KEY_SAVE = "sfs_key.txt"

local function getHWID()
    local ok,id=pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    return ok and id or "UNKNOWN"
end

local function validateKeyOnline(key, hwid)
    local ok,result=pcall(function()
        return HttpService:JSONDecode(
            game:HttpGet(SERVER_URL.."?key="..key.."&hwid="..HttpService:UrlEncode(hwid))
        )
    end)
    if ok and result then return result.valid,result.message end
    return false,"Could not connect to key server"
end

local function loadSavedKey()
    local ok,data=pcall(function()
        if isfile(KEY_SAVE) then
            return HttpService:JSONDecode(readfile(KEY_SAVE))
        end
    end)
    if ok and data and data.key then return data.key,data.hwid end
    return nil,nil
end

local function saveKey(key,hwid)
    pcall(function()
        writefile(KEY_SAVE,HttpService:JSONEncode({key=key,hwid=hwid}))
    end)
end

