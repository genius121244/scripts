            equipSword()
        end
    end
end)

localplr.CharacterAdded:Connect(function()
    if not scriptEnabled then return end
    task.wait(3)
    equipSword()
    task.wait(1)
    if isAtBase() then
        travelToArea()
        task.wait(8)
        equipSword()
    end
end)

local function findNearestTarget(rootPart)
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return nil end
    local nearest = nil
    local shortestDistance = math.huge
    for i, obj in ipairs(npcsFolder:GetChildren()) do
        for j, name in ipairs(TARGET_NAMES) do
            if obj.Name == name then
                local npcHumanoid = obj:FindFirstChildWhichIsA("Humanoid")
                if npcHumanoid and npcHumanoid.Health > 0 then
                    local distance = (rootPart.Position - obj:GetPivot().Position).Magnitude
                    if distance < shortestDistance and distance < MAX_TARGET_DISTANCE then
                        shortestDistance = distance
                        nearest = obj
                    end
                end
            end
        end
    end
    return nearest
end

local function getCharacter()
    local character = localplr.Character
    if not character then
        localplr.CharacterAdded:Wait()
        character = localplr.Character
    end
    return character
end

local function computePath(rootPart, targetPos)
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = false
    })
    local ok = pcall(function()
        path:ComputeAsync(rootPart.Position, targetPos)
    end)
    if ok and path.Status == Enum.PathStatus.Success then
        return path:GetWaypoints()
    end
    return nil
end

local lastTarget = nil
local waypoints = {}
local waypointIndex = 1
local lastWaypointIndex = 0
local stuckTimer = 0
local lastPos = nil
local lastMoveTarget = nil
local isUnstucking = false
local stuckResetTimer = 0

task.spawn(function()
    while true do
        task.wait(0.1)
        if not scriptEnabled then
            isAttacking = false
            continue
        end
        if isUnstucking then continue end

        local character = getCharacter()
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not rootPart then continue end

        local target = findNearestTarget(rootPart)
        if not target then
            isAttacking = false
            setStatus("Finding target...")
            continue
        end

        local targetPos = target:GetPivot().Position
        local dist = (rootPart.Position - targetPos).Magnitude

        if target ~= lastTarget then
            lastTarget = target
            waypointIndex = 1
            lastWaypointIndex = 0
            lastMoveTarget = nil
            isAttacking = false
            stuckResetTimer = 0
            if selectedMovement == "Pathfind" then
                waypoints = computePath(rootPart, targetPos) or {}
            end
        end

        if dist < 10 then
            isAttacking = true
            stuckResetTimer = 0
            setStatus("Attacking " .. target.Name)
            lastMoveTarget = nil
            pcall(function()
                rootPart.CFrame = CFrame.new(
                    rootPart.Position,
                    Vector3.new(targetPos.X, rootPart.Position.Y, targetPos.Z)
                )
            end)
        else
            isAttacking = false

            if selectedMovement == "Teleport" then
                setStatus("Teleporting to " .. target.Name)
                if dist > 6 then
                    teleportToTarget(target)
                end
                task.wait(0.1)
            else
                setStatus("Walking to " .. target.Name)

                if lastPos then
                    stuckTimer = stuckTimer + 0.1
                    stuckResetTimer = stuckResetTimer + 0.1

                    if stuckTimer >= 0.8 then
                        local moved = (rootPart.Position - lastPos).Magnitude
                        if moved < 0.5 then
                            isUnstucking = true
                            setStatus("Stuck, jumping...")
                            humanoid:MoveTo(rootPart.Position)
                            task.wait(0.1)
                            humanoid.Jump = true
                            task.wait(0.3)
                            humanoid.Jump = true
                            task.wait(0.3)
                            waypoints = computePath(rootPart, targetPos) or {}
                            waypointIndex = 1
                            lastWaypointIndex = 0
                            lastMoveTarget = nil
                            isUnstucking = false
                        end
                        stuckTimer = 0
                    end

                    if stuckResetTimer >= 10 then
                        local moved = (rootPart.Position - lastPos).Magnitude
                        if moved < 2 then
                            setStatus("Stuck too long, resetting...")
                            isAttacking = false
                            isUnstucking = false
                            stuckResetTimer = 0
                            lastTarget = nil
                            waypoints = {}
                            resetCharacter()
                            repeat task.wait(0.1) until
                                localplr.Character and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid") and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid").Health > 0
                            task.wait(3)
                            equipSword()
                            task.wait(1)
                            travelToArea()
                            task.wait(8)
                            equipSword()
                        else
                            stuckResetTimer = 0
                        end
                    end
                end
                lastPos = rootPart.Position

                if #waypoints > 0 and waypointIndex <= #waypoints then
                    local waypoint = waypoints[waypointIndex]
                    if (rootPart.Position - waypoint.Position).Magnitude < 4 then
                        waypointIndex = waypointIndex + 1
                        lastMoveTarget = nil
                    end
                    if waypointIndex ~= lastWaypointIndex and waypointIndex <= #waypoints then
                        local nextWaypoint = waypoints[waypointIndex]
                        if nextWaypoint.Action == Enum.PathWaypointAction.Jump then
                            humanoid.Jump = true
                        end
                        humanoid:MoveTo(nextWaypoint.Position)
                        lastWaypointIndex = waypointIndex
                    end
                else
                    if lastMoveTarget ~= targetPos then
                        humanoid:MoveTo(targetPos)
                        lastMoveTarget = targetPos
                    end
                end
            end
        end
    end
end)
