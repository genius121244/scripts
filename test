local function parsePrice(text)
    if not text then return math.huge end
    text = text:gsub(",", ""):gsub("%$", "")
    local clean = text:match("([%d%.]+%a*)")
    if not clean then return math.huge end
    local num = tonumber(clean:match("[%d%.]+"))
    if not num then return math.huge end
    local suffix = clean:match("%a+")
    if suffix then
        suffix = suffix:upper()
        if suffix == "K" then num = num * 1e3
        elseif suffix == "M" then num = num * 1e6
        elseif suffix == "B" then num = num * 1e9
        elseif suffix == "T" then num = num * 1e12
        elseif suffix == "QD" or suffix == "Q" then num = num * 1e15
        elseif suffix == "QN" then num = num * 1e18
        elseif suffix == "S" then num = num * 1e21
        elseif suffix == "OC" then num = num * 1e27
        elseif suffix == "N" then num = num * 1e30
        end
    end
    return num
end

local function getCash()
    local ok, result = pcall(function()
        return localplr.PlayerGui.Main.Top.Cash.Amount.Text
    end)
    if ok then return parsePrice(result) end
    return 0
end

local function fireButton(button)
    -- try firesignal first (wider executor support)
    local ok = pcall(function()
        firesignal(button.MouseButton1Click)
    end)
    if not ok then
        -- fallback to getconnections
        pcall(function()
            for _, connection in pairs(getconnections(button.MouseButton1Click)) do
                connection:Fire()
            end
        end)
    end
end

