-- auto upgrade loop
task.spawn(function()
    while true do
        task.wait(1)
        local anyEnabled = false
        for _, v in pairs(upgradeEnabled) do
            if v then anyEnabled = true break end
        end
        if not anyEnabled then continue end

        local cash = getCash()
        local playerGui = localplr.PlayerGui
        local machines = {"Conveyor", "Appraiser", "Polisher", "Upgrader", "Molder", "Classifier", "Enchanter", "Ascender"}
        local backboardMachines = {"Appraiser", "Polisher", "Upgrader", "Molder", "Classifier", "Enchanter"}
        local cheapestCost = math.huge
        local cheapestButton = nil

        for _, machine in ipairs(machines) do
            if upgradeEnabled[machine] then
                pcall(function()
                    local upgradeBtn = playerGui.Main.Upgrades.Main[machine].Upgrade
                    local costLabel = upgradeBtn:FindFirstChild("Cost")
                    if costLabel
                        and not costLabel.Text:find("MAXED")
                        and not costLabel.Text:find("%?")
                        and not costLabel.Text:find("Prestige") then
                        local cost = parsePrice(costLabel.Text)
                        if cost <= cash and cost < cheapestCost then
                            cheapestCost = cost
                            cheapestButton = upgradeBtn
                        end
                    end
                end)
            end
        end

        for _, machine in ipairs(backboardMachines) do
            if upgradeEnabled[machine] then
                pcall(function()
                    local backUpgrades = playerGui.Backboard[machine].Main.Upgrades.Main
                    for _, upgradeFrame in ipairs(backUpgrades:GetChildren()) do
                        pcall(function()
                            local upgradeBtn = upgradeFrame:FindFirstChild("Upgrade")
                            if upgradeBtn then
                                local costLabel = upgradeBtn:FindFirstChild("Cost")
                                if costLabel and not costLabel.Text:find("%?") and costLabel.Text:find("Purchase") then
                                    local cost = parsePrice(costLabel.Text)
                                    if cost <= cash and cost < cheapestCost then
                                        cheapestCost = cost
                                        cheapestButton = upgradeBtn
                                    end
                                end
                            end
                        end)
                    end
                end)

                pcall(function()
                    local sideBtn = playerGui.Main.Upgrades.Main[machine].Upgrade
                    local sideCost = sideBtn:FindFirstChild("Cost")
                    local sideIsPrestige = sideCost and sideCost.Text:find("Prestige")
                    if sideIsPrestige then
                        local prestigeBtn = playerGui.Backboard[machine].Main.Upgrades.Prestige.Upgrade
                        local costLabel = prestigeBtn:FindFirstChild("Cost")
                        if costLabel and not costLabel.Text:find("%?") and costLabel.Text:find("Prestige") then
                            local cost = parsePrice(costLabel.Text)
                            if cost <= cash and cost < cheapestCost then
                                cheapestCost = cost
                                cheapestButton = prestigeBtn
                            end
                        end
                    end
                end)
            end
        end

        if cheapestButton then
            print("upgrading: " .. cheapestButton:GetFullName())
            fireButton(cheapestButton)
            task.wait(0.5)
        end
    end
end)

