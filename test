end

local function isSwordEquipped()
    if not localplr.Character then return false end
    for _, v in ipairs(localplr.Character:GetChildren()) do
        if v:IsA("Tool") then return true end
    end
    return false
end

local function isAtBase()
    local character = localplr.Character
    if not character then return true end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return true end
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return true end
    for _, obj in ipairs(npcsFolder:GetChildren()) do
        for _, name in ipairs(TARGET_NAMES) do
            if obj.Name == name then
                local h = obj:FindFirstChildWhichIsA("Humanoid")
                local dist = (rootPart.Position - obj:GetPivot().Position).Magnitude
                if h and h.Health > 0 and dist < MAX_TARGET_DISTANCE then
                    return false
                end
            end
        end
    end
    return true
end

local function resetCharacter()
    pcall(function()
        local character = localplr.Character
        if character then
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then rootPart.Anchored = false end
            character.Humanoid.Health = 0
        end
    end)
end

local function teleportToTarget(target)
    pcall(function()
        local character = localplr.Character
        if not character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        local targetPos = target:GetPivot().Position
        local direction = (rootPart.Position - targetPos)
        direction = Vector3.new(direction.X, 0, direction.Z).Unit
        local offsetPos = targetPos + (direction * 4) + Vector3.new(0, 3, 0)
        rootPart.CFrame = CFrame.new(offsetPos, targetPos)
    end)
end

